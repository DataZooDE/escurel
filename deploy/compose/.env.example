# escurel generic deploy — copy to `.env` and edit.
#
# Every ESCUREL_* var maps to a TOML key path, upper-snake-cased
# (`[server] data_dir` -> ESCUREL_SERVER_DATA_DIR). Full table:
# docs/deploy/README.md and crates/escurel-server/src/config.rs.

# --- core -------------------------------------------------------------
ESCUREL_TENANT=default
# Derived-index boot policy:
#   always      drop + rebuild the DuckDB index from the markdown LaneStore
#               on every start (image default; safe against the vss HNSW
#               persistence-reload segfault; re-embeds the corpus at boot).
#   if-missing  reuse an existing index; rebuild only when absent (fast
#               restart, no re-embed). Use this if you don't hit the segfault.
ESCUREL_REBUILD_INDEX_ON_BOOT=always

# --- storage ----------------------------------------------------------
# fs: on the mounted /data volume (default). s3: object-store blob offload
# (set ESCUREL_STORAGE_S3_* — see docs/deploy/README.md).
ESCUREL_STORAGE_BACKEND=fs

# --- embedding --------------------------------------------------------
# zero          no-op vectors — dev / air-gapped smoke tests.
# gemini        hosted HTTP API — set ESCUREL_GEMINI_API_KEY.
# embeddinggemma local candle model — needs the embeddinggemma-feature image
#               plus a baked/mounted model path (offline enterprise).
ESCUREL_EMBEDDING_PROVIDER=zero
ESCUREL_EMBEDDING_DIM=768
# ESCUREL_GEMINI_API_KEY=

# --- auth -------------------------------------------------------------
# UNSET issuer => UNAUTHENTICATED dev mode (open gateway). Set these for
# anything real; the tenant claim must equal ESCUREL_TENANT or requests 403.
# ESCUREL_AUTH_OIDC_ISSUER=https://auth.example.com/realms/main
# ESCUREL_AUTH_OIDC_AUDIENCE=escurel
# ESCUREL_AUTH_TENANT_CLAIM=tenant
# ESCUREL_AUTH_ADMIN_ROLE_CLAIM=roles
# ESCUREL_AUTH_ADMIN_ROLE_VALUE=escurel:admin

# --- observability ----------------------------------------------------
# OTLP endpoint for traces (unset => tracing no-op). Logs are JSON on stdout.
# ESCUREL_OBSERVABILITY_OTLP_ENDPOINT=http://otel-collector:4317

# --- host port mapping (compose only) ---------------------------------
ESCUREL_HTTP_PORT=8080
ESCUREL_METRICS_PORT=9090
