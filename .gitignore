# Rust
/target/
**/*.rs.bk
# Git worktrees hosted inside the repo (e.g. .worktrees/runner).
/.worktrees/
# Cargo.lock is COMMITTED for this workspace (native deps via
# libduckdb-sys; the workspace produces binaries from M3 onwards).
# NOTE: gitignore does NOT support inline comments — `#` only starts a
# comment at column 0. Keep comments on their own line above the pattern.

# IDE / editor
/.idea/
/.vscode/
*.swp
*.swo
.DS_Store

# Secrets / local config
.env
.env.*
!.env.example

# DuckDB scratch (evaluation harnesses, local runs)
*.duckdb
*.duckdb.wal
*.duckdb.tmp
*.db-shm
*.db-wal

# Doc build artefacts
/docs/build/
/docs/book/

# OS
Thumbs.db

# Claude Code harness local state. We *do* track the
# escurel-platform skill (it is part of the consumer contract — see
# .claude/skills/escurel-platform/SKILL.md and CHANGELOG.md), but
# everything else under .claude/ is local to the developer's
# machine (per-agent worktrees, scheduled-task locks, transient
# logs). Whitelist the skill directory via a re-include.
/.claude/*
!/.claude/skills/
/.claude/skills/*
!/.claude/skills/escurel-platform/
